#!/usr/bin/env zsh

PROJECTS_DIR="$HOME/Projects"

if [[ ! -d "$PROJECTS_DIR" ]]; then
  echo "Error: $PROJECTS_DIR does not exist."
  exit 1
fi

PROJECT=$(ls -1 "$PROJECTS_DIR" | fzf --prompt="Select a project: " --height=40%)

if [[ -z "$PROJECT" ]]; then
  echo "No project selected."
  exit 0
fi

PROJECT_PATH="$PROJECTS_DIR/$PROJECT"
SESSION_NAME=$(basename "$PROJECT" | tr '[:upper:]' '[:lower:]' | tr ' ' '_')

cd "$PROJECT_PATH"

SESSION_STATUS=$(NO_COLOR=1 zellij list-sessions 2>/dev/null | grep "^$SESSION_NAME ")

if [[ -n "$SESSION_STATUS" ]] && ! echo "$SESSION_STATUS" | grep -q "EXITED"; then
  zellij attach "$SESSION_NAME"
  exit $?
fi

# Remove any dead/exited session with this name before creating fresh
zellij delete-session "$SESSION_NAME" 2>/dev/null || true

LAYOUT=$(mktemp /tmp/zellij-layout-XXXXXX.kdl)
cat > "$LAYOUT" <<EOF
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="editor" {
        pane {
            command "nvim"
            args "."
        }
    }
    tab name="claude" {
        pane {
            command "claude"
        }
    }
    tab name="git" {
        pane {
            command "lazygit"
        }
    }
    tab name="shell" {
        pane
    }
}
EOF
zellij --session "$SESSION_NAME" --new-session-with-layout "$LAYOUT"
rm -f "$LAYOUT"
