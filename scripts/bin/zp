#!/usr/bin/env zsh

PROJECTS_DIR="$HOME/Projects"

if [[ ! -d "$PROJECTS_DIR" ]]; then
  echo "Error: $PROJECTS_DIR does not exist."
  exit 1
fi

if [[ -n "$1" ]]; then
  PROJECT=$(ls -1 "$PROJECTS_DIR" | grep -i "$1" | head -1)
  if [[ -z "$PROJECT" ]]; then
    echo "No project matching '$1'."
    exit 1
  fi
else
  PROJECT=$(ls -1 "$PROJECTS_DIR" | fzf --prompt="Select a project: " --height=40%)
fi

if [[ -z "$PROJECT" ]]; then
  echo "No project selected."
  exit 0
fi

PROJECT_PATH="$PROJECTS_DIR/$PROJECT"
SESSION_NAME=$(basename "$PROJECT" | tr '[:upper:]' '[:lower:]' | tr ' ' '_')

cd "$PROJECT_PATH"

SESSION_STATUS=$(zellij list-sessions 2>/dev/null | sed $'s/\033\[[0-9;]*m//g' | grep "^$SESSION_NAME ")

if [[ -n "$SESSION_STATUS" ]] && ! echo "$SESSION_STATUS" | grep -q "EXITED"; then
  zellij attach "$SESSION_NAME"
  exit $?
elif [[ -n "$SESSION_STATUS" ]]; then
  zellij attach "$SESSION_NAME" --create --force-run-commands
  exit $?
fi

LAYOUT=$(mktemp /tmp/zellij-layout-XXXXXX.kdl)
cat > "$LAYOUT" <<EOF
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="editor" {
        pane {
            command "nvim"
            args "."
        }
    }
    tab name="claude" {
        pane {
            command "claude"
        }
    }
    tab name="git" {
        pane {
            command "lazygit"
        }
    }
    tab name="shell" {
        pane
    }
}
EOF
zellij --session "$SESSION_NAME" --new-session-with-layout "$LAYOUT"
rm -f "$LAYOUT"
